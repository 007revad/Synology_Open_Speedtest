#!/bin/bash

PKG_NAME=$(basename "$SYNOPKG_PKGDEST")
VAR_DIR="/var/packages/$PKG_NAME/var"
UI_DIR="/var/packages/$PKG_NAME/target/ui"

log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$VAR_DIR/install.log" 2>/dev/null || echo "$1"
}

log_message "Post-installation starting for package: $PKG_NAME"

if mkdir -p "$VAR_DIR"; then
    log_message "VAR_DIR created: $VAR_DIR"
else
    log_message "Error: Failed to create VAR_DIR"
    exit 1
fi

# Remove spurious files injected by the package builder
rm -f  "$UI_DIR/Makefile"
rm -f  "$UI_DIR/index.conf"
rm -f  "$UI_DIR/helptoc.conf"
rm -rf "$UI_DIR/help"
rm -rf "$UI_DIR/texts"
rm -f  "$UI_DIR/ui"  # self-referencing symlink
log_message "Removed spurious package builder files"

# Create web interface symlink
if ln -sf "/var/packages/$PKG_NAME/target/ui" \
          "/usr/syno/synoman/webman/3rdparty/$PKG_NAME"; then
    log_message "Created web interface symlink"
else
    log_message "Error: Failed to create web interface symlink"
    exit 1
fi

# Set execute permission on resize.cgi
chmod +x "$UI_DIR/resize.cgi" 2>/dev/null
log_message "Set execute permission on resize.cgi"

# Set execute permission on upload.cgi
chmod +x "$UI_DIR/upload.cgi" 2>/dev/null
log_message "Set execute permission on upload.cgi"

# Create 500MB download test file
DOWNLOAD_FILE="$UI_DIR/downloading"
if dd if=/dev/zero of="$DOWNLOAD_FILE" bs=1M count=500 2>/dev/null; then
    log_message "Created 500MB downloading test file"
    # Make downloading writable
    chmod 666 "$DOWNLOAD_FILE"
else
    log_message "Error: Failed to create downloading test file"
    exit 1
fi

log_message "Post-installation completed successfully"
echo >> "$VAR_DIR/install.log"
exit 0
