#!/bin/sh

# Pre-installation script for Change Panel Size
echo "Pre-installation check starting..."

# Handle presets first (if any) - Continue even if an error occurs
if [ -x "$(dirname $0)/_presets" ]; then
    "$(dirname $0)"/_presets $0 "$@" || echo "Presets script failed, continuing..."
fi

# Check default permissions - set them more leniently
#if [ "$(id -u)" != "0" ]; then
#    echo "Warning: This package works best with root privileges."
#    # exit 1 Instead, just show a warning
#fi

# Check if you have the required system commands
MISSING_COMMANDS=""
for cmd in bash sh mkdir chmod ln; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        MISSING_COMMANDS="$MISSING_COMMANDS $cmd"
    fi
done

if [ -n "$MISSING_COMMANDS" ]; then
    echo "Warning: Some required commands are missing:$MISSING_COMMANDS"
    echo "Installation may fail. Please ensure these commands are available."
    # Just display a warning and continue
fi

# Check if running inside a virtual machine
#if grep -qi 'hypervisor' /proc/cpuinfo; then
#  echo "This package is not recommended for installation within a virtual machine environment. It does not provide S.M.A.R.T. information for virtual disks."
#  # Just display a warning and continue
#  # exit 1
#fi

echo "Pre-installation check completed."
exit 0
